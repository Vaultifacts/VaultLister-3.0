# .semgrepignore - paths excluded from Semgrep scanning
# Documentation and evidence files - not production code
claude-docs/
docs/evidence/
memory/
design/
# Static test fixtures and snapshots
*.snap
# Python scripts targeting localhost (dev/test only, not production paths)
scripts/*.py
# Seed data SQL files
src/backend/db/seeds/
# API documentation pages using CDN resources (developer tools, not user-facing)
public/api-docs/
public/api-docs.html
# Generated/compiled frontend bundles — source files are scanned instead
src/frontend/app.js
src/frontend/core-bundle.js
dist/
# False positives: insecure-document-method — all innerHTML assignments in these files
# go through sanitizeHTML() (DOMPurify wrapper defined in utils.js). Verified 2026-04-13.
src/frontend/core/utils.js
src/frontend/handlers/handlers-core.js
src/frontend/handlers/handlers-community-help.js
src/frontend/handlers/handlers-intelligence.js
src/frontend/handlers/handlers-inventory-catalog.js
