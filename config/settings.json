{
  "app": {
    "name": "VaultLister",
    "version": "1.0.0",
    "port": 3000,
    "host": "localhost"
  },
  "database": {
    "path": "./data/vaultlister.db",
    "backupPath": "./data/backups"
  },
  "jwt": {
    "expiresIn": "7d",
    "refreshExpiresIn": "30d"
  },
  "Session Behavior Settings": {
  "auto_compact": true,
  "show_tips": false,
  "prompt_suggestions": false,
  "thinking_mode": true,
  "rewind_code": true,
  "verbose_output": false,
  "terminal_progress_bar": true,
  "default_permission_mode": "plan",
  "respect_gitignore": true
  },
  "UI & Display Settings": {
  "theme": "dark",
  "notifications": "off",
  "output_style": "default",
  "language": "en",
  "show_code_diff_footer": true
  },
  "Model & Performance Settings": {
  "default_model": "claude-3-5-sonnet-20241022",
  "editor_mode": "vscode",
  "auto_connect_to_ide": false,
  "claude_in_chrome": false
  },
  "platforms": {
    "poshmark": {
      "name": "Poshmark",
      "icon": "poshmark",
      "categories": ["Women", "Men", "Kids", "Home", "Electronics"],
      "maxPhotos": 16,
      "maxTitleLength": 80,
      "maxDescriptionLength": 1500
    },
    "ebay": {
      "name": "eBay",
      "icon": "ebay",
      "categories": ["Clothing", "Electronics", "Home & Garden", "Collectibles"],
      "maxPhotos": 24,
      "maxTitleLength": 80,
      "maxDescriptionLength": 4000
    },
    "mercari": {
      "name": "Mercari",
      "icon": "mercari",
      "categories": ["Women", "Men", "Electronics", "Home", "Toys"],
      "maxPhotos": 12,
      "maxTitleLength": 40,
      "maxDescriptionLength": 1000
    },
    "depop": {
      "name": "Depop",
      "icon": "depop",
      "categories": ["Womenswear", "Menswear", "Jewelry", "Bags"],
      "maxPhotos": 4,
      "maxTitleLength": 150,
      "maxDescriptionLength": 1000
    },
    "grailed": {
      "name": "Grailed",
      "icon": "grailed",
      "categories": ["Tops", "Bottoms", "Outerwear", "Footwear", "Accessories"],
      "maxPhotos": 20,
      "maxTitleLength": 60,
      "maxDescriptionLength": 2000
    },
    "facebook": {
      "name": "Facebook Marketplace",
      "icon": "facebook",
      "categories": ["Clothing", "Electronics", "Home", "Vehicles"],
      "maxPhotos": 10,
      "maxTitleLength": 100,
      "maxDescriptionLength": 2000
    },
    "etsy": {
      "name": "Etsy",
      "icon": "etsy",
      "categories": ["Vintage", "Handmade", "Supplies"],
      "maxPhotos": 10,
      "maxTitleLength": 140,
      "maxDescriptionLength": 10000
    },
    "tradesy": {
      "name": "Tradesy",
      "icon": "tradesy",
      "categories": ["Women", "Bags", "Shoes", "Accessories"],
      "maxPhotos": 10,
      "maxTitleLength": 100,
      "maxDescriptionLength": 3000
    },
    "vestiaire": {
      "name": "Vestiaire Collective",
      "icon": "vestiaire",
      "categories": ["Women", "Men", "Kids", "Lifestyle"],
      "maxPhotos": 8,
      "maxTitleLength": 100,
      "maxDescriptionLength": 2000
    },
    "whatnot": {
      "name": "Whatnot",
      "icon": "whatnot",
      "categories": ["Clothing", "Collectibles", "Sports Cards"],
      "maxPhotos": 10,
      "maxTitleLength": 80,
      "maxDescriptionLength": 1000
    }
  },
  "automation": {
    "shareIntervalMs": 300000,
    "followIntervalMs": 600000,
    "maxDailyShares": 8000,
    "maxDailyFollows": 500,
    "maxDailyOffers": 100
  },
  "ai": {
    "maxTokens": 500,
    "titlePromptTemplate": "Generate a compelling product title for: {description}",
    "descriptionPromptTemplate": "Write a detailed product description for: {title}"
  },
  "subscription": {
    "tiers": {
      "free": {
        "name": "Free",
        "maxListings": 25,
        "maxPlatforms": 2,
        "automations": false,
        "analytics": "basic",
        "price": 0
      },
      "starter": {
        "name": "Starter",
        "maxListings": 150,
        "maxPlatforms": 5,
        "automations": true,
        "analytics": "standard",
        "price": 0
      },
      "pro": {
        "name": "Pro",
        "maxListings": -1,
        "maxPlatforms": -1,
        "automations": true,
        "analytics": "advanced",
        "price": 0
      }
    }
  },
  "sustainability": {
    "baseWaterSaved": 2700,
    "baseCO2Saved": 10,
    "baseWastePrevented": 0.5
  },
  "localization": {
    "defaultLocale": "en-US",
    "supportedLocales": ["en-US", "es-ES", "fr-FR", "de-DE", "ja-JP", "zh-CN"]
  }
}
