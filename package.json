{
  "name": "vaultlister",
  "version": "1.6.1",
  "description": "All-in-one multi-channel reselling platform",
  "type": "module",
  "scripts": {
    "dev": "bun run dev:bundle && (bun --watch scripts/build-dev-bundle.js &) && bun --watch src/backend/server.js",
    "dev:bundle": "bun scripts/build-dev-bundle.js",
    "dev:bundle:min": "bun run dev:bundle && bun build src/frontend/core-bundle.js --outfile dist/core-bundle.js --minify",
    "dev:watch": "bun --watch scripts/build-dev-bundle.js",
    "dev:bg": "bun scripts/server-manager.js start",
    "dev:test-bg": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/start-test-bg.ps1",
    "dev:stop": "bun scripts/server-manager.js stop",
    "dev:status": "bun scripts/server-manager.js status",
    "test:unit": "bun run test:setup && bun test src/tests/",
    "test:setup": "bun run dev:stop && bun scripts/kill-port.js 3100 && bun run dev:test-bg",
    "start": "bun run src/backend/server.js",
    "build": "bun scripts/build-dev-bundle.js && bun scripts/build-frontend.js",
    "build:prod": "NODE_ENV=production bun scripts/build-frontend.js",
    "build:analyze": "bun scripts/build-frontend.js 2>&1 | tee bundle-stats.txt",
    "test": "bun run test:setup && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/run-bun-tests.ps1",
    "test:coverage": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/set-env-and-run.ps1 -EnvVars \"NODE_ENV=test\",\"TEST_BASE_URL=http://localhost:3000\" -Command \"bun test --coverage\"",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage src/tests/",
    "test:api": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/set-env-and-run.ps1 -EnvVars \"NODE_ENV=test\",\"TEST_BASE_URL=http://localhost:3000\" -Command \"bun test src/tests/api.test.js\"",
    "test:security": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/set-env-and-run.ps1 -EnvVars \"NODE_ENV=test\",\"TEST_BASE_URL=http://localhost:3000\" -Command \"bun test src/tests/security.test.js\"",
    "test:e2e": "node scripts/run-e2e-chunks.js",
    "test:e2e:chunk": "node scripts/run-e2e-chunks.js --chunk",
    "test:e2e:list": "node scripts/run-e2e-chunks.js --list",
    "test:e2e:all": "bun run test:setup && NODE_ENV=test PORT=3100 node node_modules/@playwright/test/cli.js test --project=chromium --workers=2",
    "test:e2e:smoke": "node node_modules/@playwright/test/cli.js test --project=chromium --workers=1 e2e/tests/smoke-auth.spec.js e2e/tests/smoke-settings.spec.js e2e/tests/smoke-integrations.spec.js e2e/tests/smoke-listing-create.spec.js e2e/tests/smoke-listing-draft.spec.js e2e/tests/smoke-listing-publish-safe.spec.js",
    "test:e2e:ui": "bun run test:setup && NODE_ENV=test PORT=3100 node node_modules/@playwright/test/cli.js test --ui --project=chromium",
    "test:e2e:headed": "bun run test:setup && NODE_ENV=test PORT=3100 node node_modules/@playwright/test/cli.js test --headed --project=chromium",
    "test:mobile-audit": "node -r dotenv/config node_modules/@playwright/test/cli.js test --config playwright.bs-cdp.config.js",
    "test:all": "bun run test:setup && bun run test:api && bun run test:security && NODE_ENV=test PORT=3100 node node_modules/@playwright/test/cli.js test",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/run-full-validation.ps1",
    "audit:ethics": "bun run scripts/ethics-audit.js",
    "audit:lighthouse": "bun run scripts/lighthouse-audit.js",
    "audit:all": "bun run audit:ethics && bun run audit:lighthouse",
    "setup": "bun install && bun run db:init && bun run db:seed",
    "db:init": "bun run src/backend/db/init.js",
    "db:seed": "bun run src/backend/db/seed.js",
    "db:reset": "bun run db:init && bun run db:seed",
    "db:backup": "bun run scripts/pg-backup.js",
    "db:backup:compress": "bun run scripts/pg-backup.js --compress",
    "db:restore": "bun run scripts/pg-restore.js",
    "automation:test": "bun run src/shared/automations/test-runner.js",
    "poshmark:login": "node scripts/poshmark-login.js",
    "poshmark:stealth-test": "node scripts/stealth-fingerprint-test.js",
    "dev:clean": "node -e \"const{rmSync,mkdirSync}=require('fs');for(const d of['data','logs','screenshots']){try{rmSync(d,{recursive:true})}catch{};try{mkdirSync(d,{recursive:true})}catch{}}\"",
    "visual-test": "node scripts/visual-test.js",
    "test:visual": "node scripts/visual-test.js",
    "test:visual:baseline": "node scripts/visual-test.js --baseline",
    "ops:health": "node scripts/launch-ops-check.mjs http://localhost:3000",
    "ops:health:prod": "node scripts/launch-ops-check.mjs https://vaultlister.com",
    "ops:smoke": "node scripts/launch-ops-check.mjs http://localhost:3000 --all",
    "ops:smoke:prod": "node scripts/launch-ops-check.mjs https://vaultlister.com --all",
    "ops:queue": "bun scripts/queue-ops.mjs",
    "ops:railway": "bun scripts/verify-railway-deploy.mjs",
    "lint": "bun run lint:syntax && bun run lint:html && bun run lint:css && echo 'Lint OK'",
    "lint:syntax": "node --check src/frontend/init.js && node --check src/frontend/core-bundle.js && node --check src/backend/server.js && echo 'Syntax OK'",
    "lint:html": "npx html-validate public/landing.html public/pricing.html public/contact.html public/changelog.html public/platforms.html public/terms.html public/privacy.html && echo 'HTML OK'",
    "lint:css": "npx stylelint 'src/frontend/styles/**/*.css' && echo 'CSS OK'",
    "preflight": "bun scripts/preflight-check.js",
    "validate:env": "node scripts/validate-env.js",
    "postinstall": "node scripts/validate-env.js || true",
    "prepare": "husky install || true",
    "check:credentials": "bun scripts/check-publish-credentials.js",
    "test:automation": "bun scripts/test-publish-automation.js",
    "audit:tail": "bun scripts/tail-audit.js",
    "open-items": "bun scripts/generate-open-items.mjs",
    "open-items:check": "bun scripts/generate-open-items.mjs --check",
    "audit": "npm i --package-lock-only --ignore-scripts --silent && npx better-npm-audit audit --level moderate",
    "test:e2e:public": "node node_modules/@playwright/test/cli.js test e2e/tests/public-pages.e2e.js --project=chromium",
    "find-unused": "npx knip",
    "find-unused-deps": "npx depcheck --ignores='@types/bun,husky,purgecss,pixelmatch,pngjs,browserstack-node-sdk'",
    "format": "npx prettier --write 'src/**/*.js' 'scripts/**/*.js' 'public/*.html'",
    "format:check": "npx prettier --check 'src/**/*.js' 'scripts/**/*.js' 'public/*.html'",
    "lint:js": "npx eslint --max-warnings 1300",
    "sort-pkg": "npx sort-package-json",
    "bundlesize": "node -e \"const s=require('fs').statSync('dist/core-bundle.js').size;const mb=(s/1e6).toFixed(2);console.log('core-bundle.js:',mb,'MB');if(s>1.5e6){console.error('FAIL: exceeds 1.5MB');process.exit(1)}else{console.log('PASS')}\"",
    "lighthouse": "npx lhci autorun",
    "test:load": "k6 run scripts/load-test.k6.js",
    "dev:server": "bun --watch src/backend/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.679.0",
    "@logtail/node": "^0.5.8",
    "@sentry/node": "^10.45.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "camoufox-js": "^0.10.2",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "otplib": "^13.2.1",
    "playwright": "1.59.1",
    "playwright-extra": "^4.3.6",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "stripe": "^17.0.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.59.1",
    "@types/bun": "^1.1.0",
    "better-npm-audit": "^3.11.0",
    "browserstack-node-sdk": "^1.52.1",
    "depcheck": "^1.4.7",
    "dockerfilelint": "^1.8.0",
    "dompurify": "^3.4.1",
    "eslint": "^10.2.0",
    "html-validate": "^10.12.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "purgecss": "^8.0.0",
    "sort-package-json": "^3.6.1",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "yaml-lint": "^1.7.0"
  },
  "keywords": [
    "reselling",
    "crosslisting",
    "poshmark",
    "ebay",
    "mercari",
    "inventory",
    "automation"
  ],
  "author": "VaultLister Team",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vaultifacts/VaultLister-3.0.git"
  },
  "bugs": {
    "url": "https://github.com/Vaultifacts/VaultLister-3.0/issues"
  },
  "homepage": "https://github.com/Vaultifacts/VaultLister-3.0#readme",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "trustedDependencies": [],
  "lint-staged": {
    "*.js": [
      "eslint --max-warnings 1300",
      "prettier --write"
    ],
    "*.css": [
      "stylelint"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
