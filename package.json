{
  "name": "vaultlister",
  "version": "1.6.0",
  "description": "All-in-one multi-channel reselling platform",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/build-dev-bundle.js && bun --watch src/backend/server.js",
    "dev:bundle": "bun scripts/build-dev-bundle.js",
    "dev:bg": "bun scripts/server-manager.js start",
    "dev:test-bg": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/start-test-bg.ps1",
    "dev:stop": "bun scripts/server-manager.js stop",
    "dev:status": "bun scripts/server-manager.js status",
    "test:unit": "bun run test:setup && bun test src/tests/",
    "test:setup": "bun run dev:stop && bun scripts/kill-port.js 3100 && bun run dev:test-bg",
    "start": "bun run src/backend/server.js",
    "build": "bun scripts/build-dev-bundle.js && bun scripts/build-frontend.js",
    "build:prod": "NODE_ENV=production bun scripts/build-frontend.js",
    "build:analyze": "bun scripts/build-frontend.js 2>&1 | tee bundle-stats.txt",
    "test": "bun run test:setup && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/run-bun-tests.ps1",
    "test:coverage": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/set-env-and-run.ps1 -EnvVars \"NODE_ENV=test\",\"TEST_BASE_URL=http://localhost:3000\" -Command \"bun test --coverage\"",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage src/tests/",
    "test:api": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/set-env-and-run.ps1 -EnvVars \"NODE_ENV=test\",\"TEST_BASE_URL=http://localhost:3000\" -Command \"bun test src/tests/api.test.js\"",
    "test:security": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/set-env-and-run.ps1 -EnvVars \"NODE_ENV=test\",\"TEST_BASE_URL=http://localhost:3000\" -Command \"bun test src/tests/security.test.js\"",
    "test:e2e": "node scripts/run-e2e-chunks.js",
    "test:e2e:chunk": "node scripts/run-e2e-chunks.js --chunk",
    "test:e2e:list": "node scripts/run-e2e-chunks.js --list",
    "test:e2e:all": "bun run test:setup && NODE_ENV=test PORT=3100 npx playwright test --project=chromium --workers=2",
    "test:e2e:ui": "bun run test:setup && NODE_ENV=test PORT=3100 npx playwright test --ui --project=chromium",
    "test:e2e:headed": "bun run test:setup && NODE_ENV=test PORT=3100 npx playwright test --headed --project=chromium",
    "test:all": "bun run test:setup && bun run test:api && bun run test:security && NODE_ENV=test PORT=3100 npx playwright test",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ps/run-full-validation.ps1",
"audit:ethics": "bun run scripts/ethics-audit.js",
    "audit:lighthouse": "bun run scripts/lighthouse-audit.js",
    "audit:all": "bun run audit:ethics && bun run audit:lighthouse",
    "db:init": "bun run src/backend/db/init.js",
    "db:seed": "bun run src/backend/db/seed.js",
    "db:reset": "bun run db:init && bun run db:seed",
    "db:backup": "bun run scripts/pg-backup.js",
    "db:backup:compress": "bun run scripts/pg-backup.js --compress",
    "db:restore": "bun run scripts/pg-restore.js",
    "automation:test": "bun run src/shared/automations/test-runner.js",
    "poshmark:login": "node scripts/poshmark-login.js",
    "poshmark:stealth-test": "node scripts/stealth-fingerprint-test.js",
    "dev:clean": "node -e \"const{rmSync,mkdirSync}=require('fs');for(const d of['data','logs','screenshots']){try{rmSync(d,{recursive:true})}catch{};try{mkdirSync(d,{recursive:true})}catch{}}\"",
    "visual-test": "node scripts/visual-test.js",
    "test:visual": "node scripts/visual-test.js",
"lint": "npx eslint src/backend/ src/shared/ scripts/ --max-warnings 50 && node --check src/frontend/app.js && node --check src/backend/server.js && echo 'Lint OK'",
    "lint:syntax": "node --check src/frontend/app.js && node --check src/backend/server.js && echo 'Syntax OK'",
    "validate:env": "node scripts/validate-env.js",
    "postinstall": "node scripts/validate-env.js || true",
    "prepare": "husky install || true",
    "check:credentials": "bun scripts/check-publish-credentials.js",
    "test:automation": "bun scripts/test-publish-automation.js",
    "audit:tail": "bun scripts/tail-audit.js",
"audit": "bun pm scan || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.679.0",
    "bullmq": "^5.1.0",
    "@sentry/node": "^10.45.0",
    "bcryptjs": "^2.4.3",
    "dompurify": "^3.3.3",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "resend": "^4.0.0",
    "otplib": "^13.2.1",
    "playwright": "1.58.2",
    "playwright-extra": "^4.3.6",
    "postgres": "^3.4.8",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "stripe": "^17.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.1",
    "@types/bun": "^1.1.0",
    "husky": "^9.1.7",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0"
  },
  "keywords": [
    "reselling",
    "crosslisting",
    "poshmark",
    "ebay",
    "mercari",
    "inventory",
    "automation"
  ],
  "author": "VaultLister Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vaultifacts/VaultLister-3.0.git"
  },
  "bugs": {
    "url": "https://github.com/Vaultifacts/VaultLister-3.0/issues"
  },
  "homepage": "https://github.com/Vaultifacts/VaultLister-3.0#readme",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  }
}
