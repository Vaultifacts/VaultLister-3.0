{
  "manifest_version": 3,
  "name": "VaultLister Helper",
  "version": "1.0.0",
  "description": "Quick product capture, price tracking, and cross-listing helper for VaultLister",
  "permissions": [
    "storage",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://vaultlister.com/*",
    "https://www.amazon.com/*",
    "https://www.nordstrom.com/*",
    "https://poshmark.com/*",
    "https://www.ebay.com/*",
    "https://www.mercari.com/*",
    "https://www.depop.com/*",
    "https://www.grailed.com/*",
    "https://www.etsy.com/*",
    "https://*.myshopify.com/*",
    "https://www.facebook.com/*",
    "https://www.whatnot.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/dp/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.nordstrom.com/s/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/itm/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://poshmark.com/listing/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.mercari.com/item/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.depop.com/products/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.grailed.com/listings/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.etsy.com/listing/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.myshopify.com/products/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://poshmark.com/create-listing*",
        "https://www.ebay.com/sl/sell*",
        "https://www.mercari.com/sell/*",
        "https://www.depop.com/sell/*",
        "https://www.grailed.com/listings/new*",
        "https://www.etsy.com/your/listings/*",
        "https://*.myshopify.com/admin/products/new*",
        "https://*.myshopify.com/admin/products/*"
      ],
      "js": ["content/autofill.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://poshmark.com/create-listing*",
        "https://www.depop.com/sell/*",
        "https://www.facebook.com/marketplace/create/*",
        "https://www.whatnot.com/sell*"
      ],
      "js": ["content/poster.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
