{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "[CONFIGURE]"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "openclaw-memory": {
      "command": "npx",
      "args": ["-y", "@openclaw/mcp-memory"],
      "env": {
        "MEMORY_FILE": ".openclaw/memory/context.json"
      }
    }
  }
}
