{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "msedge",
            "request": "launch",
            "name": "Open DevTools in VS Code",
            "url": "http://localhost:3000/landing.html",
            "webRoot": "${workspaceFolder}/public",
            "pathMapping": {
                "/styles": "${workspaceFolder}/src/frontend/styles",
                "/": "${workspaceFolder}/public"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Backend (Bun)",
            "runtimeExecutable": "bun",
            "runtimeArgs": [
                "--inspect",
                "src/backend/server.js"
            ],
            "env": {
                "LOG_LEVEL": "DEBUG"
            },
            "console": "integratedTerminal"
        }
    ]
}
