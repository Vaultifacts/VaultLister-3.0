# VaultLister Production Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Server Configuration
# ===========================================
NODE_ENV=production
PORT=3000

# Demo Auto-Login (remove or leave blank to disable in production)
# DEMO_EMAIL=demo@vaultlister.com
# DEMO_PASSWORD=DemoPassword123!

# CRITICAL: Generate a strong random string (min 32 chars)
# Example: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# REQUIRED - Database
# ===========================================
DATA_DIR=./data
# For production, use absolute path:
# DATA_DIR=/var/lib/vaultlister/data
# Custom database file path (default: DATA_DIR/vaultlister.db)
# DB_PATH=./data/vaultlister.db

# ===========================================
# BACKUP CONFIGURATION (Optional)
# ===========================================
# Directory for database backups (default: ./backups)
# BACKUP_DIR=./backups

# ===========================================
# TESTING & BENCHMARKS (Optional)
# ===========================================
# Base URL for load tests and benchmarks (default: http://localhost:3000)
# BASE_URL=http://localhost:3000
# Load test concurrency settings
# CONCURRENT_USERS=10
# REQUESTS_PER_USER=5

# ===========================================
# MONITORING & ALERTING (Recommended)
# ===========================================
# Sentry error tracking - get DSN from sentry.io
SENTRY_DSN=https://your-key@sentry.io/project-id

# Slack alerts for critical issues
SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Alert thresholds
MEMORY_WARNING_THRESHOLD=80
MEMORY_CRITICAL_THRESHOLD=90
ERROR_RATE_THRESHOLD=5

# ===========================================
# EMAIL CONFIGURATION (Required for notifications)
# ===========================================
# SMTP settings (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=VaultLister <noreply@vaultlister.com>

# OAuth for email integration (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
# Gmail OAuth (for receipt/order email scanning)
# GMAIL_CLIENT_ID=your-gmail-client-id
# GMAIL_CLIENT_SECRET=your-gmail-client-secret

# ===========================================
# PUSH NOTIFICATIONS (Firebase)
# ===========================================
# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ===========================================
# REDIS (Recommended for production)
# ===========================================
# Redis for caching, sessions, rate limiting
REDIS_URL=redis://localhost:6379
# Or with authentication:
# REDIS_URL=redis://:password@hostname:6379

# ===========================================
# CLOUD BACKUP (Optional)
# ===========================================
# Enable cloud backups
CLOUD_BACKUP_ENABLED=false
CLOUD_BACKUP_PROVIDER=s3

# AWS S3 settings
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=vaultlister-backups

# Or OneDrive via rclone
# CLOUD_BACKUP_PROVIDER=onedrive
# ONEDRIVE_BACKUP_PATH=/VaultLister/Backups

# ===========================================
# MARKETPLACE INTEGRATIONS (OAuth)
# ===========================================
# eBay
# EBAY_ENVIRONMENT controls sandbox vs production for ALL eBay API calls.
# Set to 'production' when you have a production eBay developer app.
EBAY_ENVIRONMENT=sandbox
# Client credentials from https://developer.ebay.com — use sandbox keys while testing.
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
# EBAY_REDIRECT_URI is the eBay RU Name (NOT a URL) — the name you register in
# Application Settings > Auth Accepted OAuth Scopes on developer.ebay.com.
# Format: YourAppName-YourAppI-YourRuN-xxxxxxxx  (sandbox has "SBX" prefix on creds)
EBAY_REDIRECT_URI=your-ebay-ru-name
# OAUTH_MODE: set to 'real' to use live eBay OAuth. 'mock' returns fake tokens instantly.
OAUTH_MODE=mock
# eBay Marketplace Account Deletion webhook (required for production keyset activation).
# EBAY_DELETION_VERIFICATION_TOKEN: any random 32+ char string — paste the same value into the
#   eBay developer portal under Alerts & Notifications > Verification token.
# EBAY_DELETION_ENDPOINT: the full public HTTPS URL eBay will POST to, e.g.:
#   https://yourdomain.com/api/webhooks/ebay/account-deletion
EBAY_DELETION_VERIFICATION_TOKEN=your-random-32-char-token-here
EBAY_DELETION_ENDPOINT=https://your-domain.com/api/webhooks/ebay/account-deletion

# Poshmark (browser automation — no public API)
POSHMARK_USERNAME=your-poshmark-email@example.com
POSHMARK_PASSWORD=your-poshmark-password

# Mercari (browser automation — no public API)
MERCARI_USERNAME=your-mercari-email@example.com
MERCARI_PASSWORD=your-mercari-password

# Depop (browser automation — no public API)
DEPOP_USERNAME=your-depop-username
DEPOP_PASSWORD=your-depop-password

# Grailed (browser automation — no public API)
GRAILED_USERNAME=your-grailed-email@example.com
GRAILED_PASSWORD=your-grailed-password

# Facebook Marketplace (browser automation — no public API)
# WARNING: Facebook detects automation. Use a dedicated account, not your personal one.
FACEBOOK_EMAIL=your-facebook-email@example.com
FACEBOOK_PASSWORD=your-facebook-password

# Whatnot (browser automation — creator API is invite-only)
WHATNOT_USERNAME=your-whatnot-email@example.com
WHATNOT_PASSWORD=your-whatnot-password

# Shopify (REST API — requires Admin API Access Token with write_products scope)
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your-admin-api-access-token

# ===========================================
# AI SERVICES (Optional)
# ===========================================
# OpenAI for AI features
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI threshold overrides (defaults shown)
# AI_FALLBACK_CONFIDENCE=0.65
# AI_PRICE_RANGE_LOW=0.8
# AI_PRICE_RANGE_HIGH=1.2
# AI_DUPLICATE_THRESHOLD=0.8
# AI_CATEGORY_CONFIDENCE=0.85

# Grok (X.AI)
GROK_API_KEY=your-grok-api-key

# ===========================================
# SECURITY SETTINGS
# ===========================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session settings
SESSION_SECRET=another-random-string-for-sessions

# WebAuthn/FIDO2 settings
RP_ID=yourdomain.com
ORIGIN=https://yourdomain.com

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_DIR=./logs

# ===========================================
# FEATURE FLAGS (Optional)
# ===========================================
FEATURE_AI_LISTING=true
FEATURE_WHATNOT_INTEGRATION=true
FEATURE_ADVANCED_ANALYTICS=true

# ===========================================
# NOTION INTEGRATION (Optional)
# ===========================================
# Internal Integration Token from Notion settings
NOTION_INTEGRATION_TOKEN=your-notion-internal-integration-token
# Enable/disable automatic sync
NOTION_SYNC_ENABLED=false
# Sync interval in minutes (minimum 15)
NOTION_SYNC_INTERVAL_MINUTES=60
# Conflict resolution strategy: manual, vaultlister_wins, notion_wins, newest_wins
NOTION_SYNC_CONFLICT_STRATEGY=manual
# Notion Page IDs (used by workflow scripts)
NOTION_MAIN_PAGE_ID=your-main-page-id
NOTION_INCOMPLETE_PAGE_ID=your-incomplete-issues-page-id
NOTION_COMPLETE_PAGE_ID=your-completed-issues-page-id
NOTION_VISUAL_TEST_PROMPT_PAGE_ID=your-visual-test-prompt-page-id

# ===========================================
# STRIPE PAYMENTS (Required for paid plans)
# ===========================================
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Webhook secret — run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Price IDs from Stripe Dashboard > Products (create one per plan)
# STRIPE_PRICE_STARTER=price_xxxxx
# STRIPE_PRICE_PRO=price_xxxxx
# STRIPE_PRICE_BUSINESS=price_xxxxx

# ===========================================
# APPLICATION URLs
# ===========================================
APP_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000
# CDN_URL=
# ASSET_VERSION=

# ===========================================
# SECURITY — SECRETS
# ===========================================
# Encryption key for stored OAuth tokens (32+ chars, generate with: openssl rand -hex 32)
# OAUTH_ENCRYPTION_KEY=your-oauth-encryption-key
# HMAC key for MFA backup code hashing
# BACKUP_CODE_SECRET=your-backup-code-secret
# HMAC key for email unsubscribe tokens
# UNSUBSCRIBE_SECRET=your-unsubscribe-secret

# ===========================================
# PROXY & TRUST
# ===========================================
# Set to 'true' if behind a reverse proxy (Nginx, Cloudflare)
# TRUST_PROXY=false

# ===========================================
# DATABASE TUNING (Optional)
# ===========================================
# DB_POOL_SIZE=5
# SLOW_QUERY_THRESHOLD=100
# DB_PROFILING=false

# ===========================================
# CLOUDINARY (Image Processing)
# ===========================================
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ===========================================
# PUSH NOTIFICATIONS — VAPID (Web Push)
# ===========================================
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key

# ===========================================
# EMAIL POLLING (Optional)
# ===========================================
# EMAIL_POLL_INTERVAL=300000
# EMAIL_MAX_FAILURES=5
# ALERT_EMAIL=admin@yourdomain.com

# ===========================================
# SOCIAL LOGIN (Optional)
# ===========================================
# Apple Sign In
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_TEAM_ID=your-apple-team-id
# APPLE_KEY_ID=your-apple-key-id
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_REDIRECT_URI=https://yourdomain.com/api/social-auth/apple/callback
# Google OAuth redirect — NOT needed for Drive/Calendar (googleOAuth.js builds it dynamically)
# Only needed for Google Social Login (Sign-In with Google):
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/social-auth/google/callback
# Facebook Login
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# ===========================================
# AI SERVICES — Additional
# ===========================================
# X.AI / Grok
# XAI_API_KEY=your-xai-api-key
# Chatbot mode: 'full' (Claude API) or 'local' (template-only)
# CHATBOT_MODE=full
# ANALYTICS_ENABLED=true

# ===========================================
# MARKETPLACE OAuth (for platforms with public APIs)
# ===========================================
# Etsy (requires app approval — https://www.etsy.com/developers)
# ETSY_CLIENT_ID=your-etsy-client-id
# ETSY_CLIENT_SECRET=your-etsy-client-secret

# Poshmark region (us, ca, au, in — defaults to us)
# POSHMARK_COUNTRY=us

# OAuth redirect base (defaults to APP_URL)
# OAUTH_REDIRECT_URI=https://yourdomain.com/api/oauth/callback

# Shopify (if using OAuth instead of Admin API token)
# SHOPIFY_CLIENT_ID=your-shopify-client-id
# SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# ===========================================
# REDIS (Optional)
# ===========================================
# REDIS_ENABLED=false

# ===========================================
# DEBUG FLAGS (Development Only — ignored in production)
# ===========================================
# DISABLE_CSRF=true
# DISABLE_RATE_LIMIT=true

# Maintenance mode — shows 503 page to all visitors (health endpoint still works)
# MAINTENANCE_MODE=true

# ===========================================
# BACKUP — rclone (Optional cloud backup)
# ===========================================
# RCLONE_PATH=/usr/local/bin/rclone
# VAULTLISTER_RCLONE_REMOTE=vaultlister-backup
# VAULTLISTER_REMOTE_PATH=/backups
