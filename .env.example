# VaultLister Production Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Server Configuration
# ===========================================
NODE_ENV=production
PORT=3000

# Demo Auto-Login (remove or leave blank to disable in production)
# DEMO_EMAIL=demo@vaultlister.com
# DEMO_PASSWORD=DemoPassword123!

# CRITICAL: Generate a strong random string (min 32 chars)
# Example: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_USE_openssl_rand_-base64_64

# Session security settings (optional — sensible defaults shown)
# MFA session validity period in seconds (default: 3600 = 1 hour)
# MFA_SESSION_EXPIRY_SECONDS=3600
# Client-side inactivity timeout hint in seconds (default: 1800 = 30 min)
# INACTIVITY_TIMEOUT_SECONDS=1800

# ===========================================
# REQUIRED - Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://vaultlister:localdev@localhost:5432/vaultlister_dev
# For production:
# DATABASE_URL=postgresql://user:password@host:5432/vaultlister_prod
# Docker Compose uses POSTGRES_PASSWORD to construct DATABASE_URL:
POSTGRES_PASSWORD=localdev

# Railway public endpoint — used by CI backup scripts and maintenance workflows (NOT for the app itself)
# DATABASE_PUBLIC_URL=postgres://user:pass@host:port/db

# DATA_DIR is no longer used — database is PostgreSQL (DATABASE_URL above)

# ===========================================
# BACKUP CONFIGURATION (Optional)
# ===========================================
# Directory for database backups (default: ./backups)
# BACKUP_DIR=./backups

# ===========================================
# TESTING & BENCHMARKS (Optional)
# ===========================================
# Base URL for load tests and benchmarks (default: http://localhost:3000)
# REQUIRED FOR PRODUCTION -- falls back to http://localhost:3000 if unset; OAuth callbacks and email links will be broken
# BASE_URL=https://yourdomain.com
# Load test concurrency settings
# CONCURRENT_USERS=10
# REQUESTS_PER_USER=5

# ===========================================
# BROWSERSTACK — Mobile Audit (Optional)
# ===========================================
# Required to run: npx browserstack-node-sdk playwright test --config playwright.browserstack.config.js
# Get credentials from https://automate.browserstack.com/dashboard
# BROWSERSTACK_USERNAME=
# BROWSERSTACK_ACCESS_KEY=
# Override live URL tested by BrowserStack (default: Railway production URL)
# VAULTLISTER_URL=https://vaultlister-app-production.up.railway.app

# ===========================================
# MONITORING & ALERTING (Recommended)
# ===========================================
# Sentry error tracking - get DSN from sentry.io
SENTRY_DSN=https://your-key@sentry.io/project-id
# Sentry DSN for frontend browser SDK — injected into <meta name="sentry-dsn"> server-side or set here for static injection
# Leave empty to disable frontend error tracking
SENTRY_DSN_FRONTEND=
# Release tag for Sentry — set via CI (e.g. RAILWAY_GIT_COMMIT_SHA) or a version string
SENTRY_RELEASE=
# Fraction of requests to trace (0.0–1.0). Use 0.1 in production (10% sampling).
# 1.0 traces everything — fine for low-traffic apps, expensive at scale.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Fraction of traced requests to profile (0.0–1.0). Must be <= SENTRY_TRACES_SAMPLE_RATE.
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Slack alerts for critical issues
SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Alert thresholds
MEMORY_WARNING_THRESHOLD=80
MEMORY_CRITICAL_THRESHOLD=90
ERROR_RATE_THRESHOLD=5

# ===========================================
# EMAIL CONFIGURATION (Required for notifications)
# ===========================================
# Resend (production) — replaces SMTP
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=VaultLister <noreply@vaultlister.com>

# OAuth for email integration (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
# Gmail OAuth (for receipt/order email scanning)
# GMAIL_CLIENT_ID=your-gmail-client-id
# GMAIL_CLIENT_SECRET=your-gmail-client-secret

# ===========================================
# PUSH NOTIFICATIONS (Firebase)
# ===========================================
# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ===========================================
# REDIS (Recommended for production)
# ===========================================
# Redis for caching, sessions, rate limiting
REDIS_URL=redis://localhost:6379
# Or with authentication:
# REDIS_URL=redis://:password@hostname:6379
REDIS_PASSWORD=your-redis-password-here

# ===========================================
# CLOUD BACKUP (Optional)
# ===========================================
# Enable cloud backups
CLOUD_BACKUP_ENABLED=false
CLOUD_BACKUP_PROVIDER=s3

# AWS S3 settings
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=vaultlister-backups

# Or OneDrive via rclone
# CLOUD_BACKUP_PROVIDER=onedrive
# ONEDRIVE_BACKUP_PATH=/VaultLister/Backups

# ===========================================
# MARKETPLACE INTEGRATIONS (OAuth)
# ===========================================
# eBay
# EBAY_ENVIRONMENT controls sandbox vs production for ALL eBay API calls.
# Set to 'sandbox' only while testing — sandbox calls never affect real listings.
EBAY_ENVIRONMENT=production
# Client credentials from https://developer.ebay.com â€” use sandbox keys while testing.
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
# EBAY_REDIRECT_URI is the eBay RU Name (NOT a URL) â€” the name you register in
# Application Settings > Auth Accepted OAuth Scopes on developer.ebay.com.
# Format: YourAppName-YourAppI-YourRuN-xxxxxxxx  (sandbox has "SBX" prefix on creds)
EBAY_REDIRECT_URI=your-ebay-ru-name
# OAUTH_MODE: set to 'mock' for development only — mock returns fake tokens instantly.
OAUTH_MODE=real
# eBay Marketplace Account Deletion webhook (required for production keyset activation).
# EBAY_DELETION_VERIFICATION_TOKEN: any random 32+ char string â€” paste the same value into the
#   eBay developer portal under Alerts & Notifications > Verification token.
# EBAY_DELETION_ENDPOINT: the full public HTTPS URL eBay will POST to, e.g.:
#   https://yourdomain.com/api/webhooks/ebay/account-deletion
EBAY_DELETION_VERIFICATION_TOKEN=your-random-32-char-token-here
EBAY_DELETION_ENDPOINT=https://your-domain.com/api/webhooks/ebay/account-deletion

# Poshmark (browser automation â€” no public API)
POSHMARK_USERNAME=your-poshmark-email@example.com
POSHMARK_PASSWORD=your-poshmark-password

# Mercari (browser automation â€” no public API)
MERCARI_USERNAME=your-mercari-email@example.com
MERCARI_PASSWORD=your-mercari-password

# Depop (legacy bot credentials — not needed when OAuth is connected via Settings > Integrations)
# DEPOP_USERNAME=your-depop-username
# DEPOP_PASSWORD=your-depop-password

# Grailed (browser automation â€” no public API)
GRAILED_USERNAME=your-grailed-email@example.com
GRAILED_PASSWORD=your-grailed-password

# Facebook Marketplace (browser automation â€” no public API)
# WARNING: Facebook detects automation. Use a dedicated account, not your personal one.
FACEBOOK_EMAIL=your-facebook-email@example.com
FACEBOOK_PASSWORD=your-facebook-password
# Optional: residential proxy for Facebook automation (advanced, reduces ban risk)
# Format: http://user:pass@host:port or socks5://user:pass@host:port
# FACEBOOK_PROXY_URL=http://user:pass@gate.smartproxy.com:7777
# Per-profile proxies (each account should use a dedicated residential IP):
# FACEBOOK_PROXY_URL_1=socks5://user:pass@proxy1.example.com:1080
# FACEBOOK_PROXY_URL_2=socks5://user:pass@proxy2.example.com:1080
# FACEBOOK_PROXY_URL_3=socks5://user:pass@proxy3.example.com:1080
# Minimum age of Facebook account in days before automation is considered safe (default: 3)
# FACEBOOK_MIN_ACCOUNT_AGE_DAYS=3

# Whatnot (browser automation â€” creator API is invite-only)
WHATNOT_USERNAME=your-whatnot-email@example.com
WHATNOT_PASSWORD=your-whatnot-password

# Shopify (REST API â€” requires Admin API Access Token with write_products scope)
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your-admin-api-access-token

# ===========================================
# AI SERVICES (Optional)
# ===========================================
# OpenAI for AI features
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
# Per-feature API key overrides (fall back to ANTHROPIC_API_KEY if not set)
VAULTLISTER_LISTING_GENERATOR=
VAULTLISTER_SUPPORT_BOT=
VAULTLISTER_BLOG_BOT=
VAULTLISTER_IMAGE_ANALYZER=
VAULTLISTER_PREDICTIONS=
VAULTLISTER_RECEIPT_PARSER=

# AI threshold overrides (defaults shown)
# AI_FALLBACK_CONFIDENCE=0.65
# AI_PRICE_RANGE_LOW=0.8
# AI_PRICE_RANGE_HIGH=1.2
# AI_DUPLICATE_THRESHOLD=0.8
# AI_CATEGORY_CONFIDENCE=0.85

GA_MEASUREMENT_PROTOCOL_SECRET=          # GA4 Measurement Protocol API secret (from GA4 → Data Streams → Measurement Protocol API secrets)

# X.AI / Grok
XAI_API_KEY=your-xai-api-key

# ===========================================
# SECURITY SETTINGS
# ===========================================
# CORS allowed origins (comma-separated)
# REQUIRED FOR PRODUCTION -- if unset, cross-origin requests may be rejected or overly permissive
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session settings
SESSION_SECRET=REPLACE_ME_USE_openssl_rand_-base64_64

# WebAuthn/FIDO2 settings
# REQUIRED FOR PRODUCTION -- falls back to localhost; passkey/MFA authentication will fail in production
RP_ID=yourdomain.com
# REQUIRED FOR PRODUCTION -- falls back to http://localhost:3000; passkey/MFA authentication will fail in production
ORIGIN=https://yourdomain.com

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_DIR=./logs
# Betterstack Telemetry — optional. When set, structured app logs are shipped to
# Betterstack in addition to stdout (Railway native drain). Omit in local dev.
BETTERSTACK_SOURCE_TOKEN=

# ===========================================
# FEATURE FLAGS (Optional)
# ===========================================
FEATURE_AI_LISTING=true
FEATURE_WHATNOT_INTEGRATION=true
FEATURE_ADVANCED_ANALYTICS=true

# ===========================================
# STRIPE PAYMENTS (Required for paid plans)
# ===========================================
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Webhook secret â€” run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Price IDs from Stripe Dashboard > Products (create one per plan)
STRIPE_PRICE_STARTER=price_1TBmAzBO26AWLnmlWjSpXDQ6
STRIPE_PRICE_PRO=price_1TBmBGBO26AWLnmlWII2cXi5
STRIPE_PRICE_BUSINESS=price_1TBmBVBO26AWLnmlFpk8UMB7

# ===========================================
# SHIPPING (Shippo - https://goshippo.com)
# ===========================================
# Required for real carrier rate quotes (USPS, UPS, FedEx) and label purchase.
# Free tier available at goshippo.com. Without this key, the /api/shipping-labels/rates
# endpoint returns 503 and batch label purchase runs in local-only mode.
# SHIPPO_API_KEY=shippo_live_your-api-key-here
EASYPOST_API_KEY=       # EasyPost API key — get at easypost.com (anti-fraud review pending)

# ===========================================
# APPLICATION URLs
# ===========================================
# REQUIRED FOR PRODUCTION -- falls back to http://localhost:3000 if unset; email links, OAuth callbacks, and billing redirects will be broken
APP_URL=https://yourdomain.com
# FRONTEND_URL=http://localhost:3000
# CDN_URL=
# ASSET_VERSION=

# ===========================================
# IMAGE STORAGE — Cloudflare R2
# IMAGE_STORAGE=local (default) or r2
# ===========================================
IMAGE_STORAGE=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vaultlister-uploads
R2_PUBLIC_URL=

# ===========================================
# SECURITY â€” SECRETS
# ===========================================
# Encryption key for stored OAuth tokens (32+ chars, generate with: openssl rand -hex 32)
# OAUTH_ENCRYPTION_KEY=your-oauth-encryption-key
# HMAC key for MFA backup code hashing
# BACKUP_CODE_SECRET=your-backup-code-secret
# HMAC key for email unsubscribe tokens
# UNSUBSCRIBE_SECRET=your-unsubscribe-secret

# ===========================================
# PROXY & TRUST
# ===========================================
# Set to 'true' if behind a reverse proxy (Nginx, Cloudflare)
# TRUST_PROXY=false

# ===========================================
# DATABASE TUNING (Optional)
# ===========================================
# DB_POOL_SIZE=5
# SLOW_QUERY_THRESHOLD=100
# DB_PROFILING=false

# ===========================================
# CLOUDINARY (Image Processing)
# ===========================================
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ===========================================
# PUSH NOTIFICATIONS â€” VAPID (Web Push)
# ===========================================
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ===========================================
# EMAIL POLLING (Optional)
# ===========================================
# EMAIL_POLL_INTERVAL=300000
# EMAIL_MAX_FAILURES=5
# ALERT_EMAIL=admin@yourdomain.com

# ===========================================
# SOCIAL LOGIN (Optional)
# ===========================================
# Apple Sign In
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_TEAM_ID=your-apple-team-id
# APPLE_KEY_ID=your-apple-key-id
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# REQUIRED FOR PRODUCTION if using Apple Sign In -- falls back to http://localhost:3000/... which Apple OAuth will reject
# APPLE_REDIRECT_URI=https://yourdomain.com/api/social-auth/apple/callback
# Google OAuth redirect â€” NOT needed for Drive/Calendar (googleOAuth.js builds it dynamically)
# Only needed for Google Social Login (Sign-In with Google):
# REQUIRED FOR PRODUCTION if using Google Login -- falls back to http://localhost:3000/... which Google OAuth will reject
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/social-auth/google/callback
# Facebook: No OAuth/Commerce API path — listing handled via Chrome extension browser automation
# FACEBOOK_APP_ID and FACEBOOK_APP_SECRET are not used

# ===========================================
# AI SERVICES â€” Additional
# ===========================================
# Chatbot mode: 'full' (Claude API) or 'local' (template-only)
# CHATBOT_MODE=full
# ANALYTICS_ENABLED=true

# ===========================================
# MARKETPLACE OAuth (for platforms with public APIs)
# ===========================================
# Etsy (requires app approval â€” https://www.etsy.com/developers)
# ETSY_CLIENT_ID=your-etsy-client-id
# ETSY_CLIENT_SECRET=your-etsy-client-secret

# Poshmark region (us, ca, au, in â€” defaults to us)
# POSHMARK_COUNTRY=us

# OAuth redirect base (defaults to APP_URL)
# OAUTH_REDIRECT_URI=https://yourdomain.com/api/oauth/callback

# Shopify (if using OAuth instead of Admin API token)
# SHOPIFY_CLIENT_ID=your-shopify-client-id
# SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# ===========================================
# REDIS (Optional)
# ===========================================
# REDIS_ENABLED=false

# ===========================================
# DEBUG FLAGS (Development Only â€” ignored in production)
# ===========================================
# DISABLE_CSRF=true
# DISABLE_RATE_LIMIT=true

# Maintenance mode â€” shows 503 page to all visitors (health endpoint still works)
# MAINTENANCE_MODE=true

# ===========================================
# EXTERNAL APIS
# ===========================================
# Currency exchange rates (default: frankfurter.app — free, no key required)
# CURRENCY_API_URL=https://api.frankfurter.app/latest

# ===========================================
# BACKUP — Backblaze B2 (pg_dump archives, Railway cron)
# ===========================================
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=vaultlister-backups

# ===========================================
# OBSERVABILITY — Grafana Cloud
# ===========================================
# Token to protect the /metrics endpoint (Grafana Cloud sets this in scrape config)
PROMETHEUS_METRICS_TOKEN=

# ===========================================
# MARKETPLACE OAuth — Internal OAuth Endpoints
# These are used by the OAuth service layer (oauthService.js) for platforms
# that have OAuth APIs. Most resellers don't need these — they use bot credentials above.
# ===========================================
# Poshmark (internal OAuth — rarely needed; bot credentials above are preferred)
# POSHMARK_CLIENT_ID=your-poshmark-client-id
# POSHMARK_CLIENT_SECRET=your-poshmark-client-secret
# POSHMARK_OAUTH_URL=https://poshmark.com/oauth/login
# POSHMARK_TOKEN_URL=https://poshmark.com/oauth/token
# POSHMARK_USER_URL=https://api.poshmark.com/api/users/me
# POSHMARK_REVOKE_URL=https://poshmark.com/oauth/revoke
# POSHMARK_DOMAIN=poshmark.com
# POSHMARK_COUNTRY=us

# Mercari (internal OAuth endpoints)
# MERCARI_CLIENT_ID=your-mercari-client-id
# MERCARI_CLIENT_SECRET=your-mercari-client-secret
# MERCARI_OAUTH_URL=https://mercari.com/oauth/login
# MERCARI_TOKEN_URL=https://api.mercari.com/oauth2/token
# MERCARI_USER_URL=https://api.mercari.com/users/me

# Depop Selling Partner API (OAuth 2.0 + PKCE — apply at partnerapi.depop.com)
DEPOP_CLIENT_ID=your-depop-client-id
DEPOP_CLIENT_SECRET=your-depop-client-secret
# Webhook signing secret (provided by Depop when you register a webhook endpoint):
# DEPOP_WEBHOOK_SECRET=your-depop-webhook-signing-secret

# Grailed (internal OAuth endpoints)
# GRAILED_CLIENT_ID=your-grailed-client-id
# GRAILED_CLIENT_SECRET=your-grailed-client-secret
# GRAILED_OAUTH_URL=https://grailed.com/oauth/authorize
# GRAILED_TOKEN_URL=https://grailed.com/oauth/token
# GRAILED_USER_URL=https://grailed.com/api/v1/users/me

# Whatnot (invite-only creator API)
# WHATNOT_CLIENT_ID=your-whatnot-client-id
# WHATNOT_CLIENT_SECRET=your-whatnot-client-secret

# Facebook OAuth/Commerce API removed — no public API for Marketplace listings.
# Listing is handled via Chrome extension browser automation (chrome-extension/content/poster.js).

# eBay bot credentials (alternative to OAuth — for Playwright automation)
# EBAY_USERNAME=your-ebay-email@example.com
# EBAY_PASSWORD=your-ebay-password

# ===========================================
# SECURITY — JWT Rotation (Optional)
# ===========================================
# Old JWT secret during rotation — verifies tokens signed with the previous key
# JWT_SECRET_OLD=your-previous-jwt-secret
# Old OAuth encryption key during rotation
# OAUTH_ENCRYPTION_KEY_OLD=your-previous-oauth-encryption-key

# ===========================================
# FEATURE FLAGS — Additional (Optional)
# ===========================================
# FEATURE_CALENDAR_SYNC=false
# FEATURE_GOOGLE_DRIVE=false

# ===========================================
# DEBUG FLAGS — Additional (Development Only)
# ===========================================
# Alias for DISABLE_RATE_LIMIT — both are checked by rate limiter middleware
# RATE_LIMIT_DISABLED=true
