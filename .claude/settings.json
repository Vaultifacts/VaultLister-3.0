{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(node *)",
      "Bash(git add src/*)",
      "Bash(git add scripts/*)",
      "Bash(git add docs/*)",
      "Bash(git add memory/*)",
      "Bash(git add audit-log.md)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git stash *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git pull)",
      "Bash(docker build *)",
      "Bash(docker-compose *)",
      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase -i*)",
      "Bash(git add -A)",
      "Bash(git add .)",
      "Bash(rm -rf *)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(--no-verify)",
      "Bash(bun run db:drop*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-bash.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-files.sh \"$CLAUDE_TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-commit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-init.sh stop"
          }
        ]
      }
    ]
  },
  "statusLine": ".claude/statusline.sh",
  "memory": [
    "memory/STATUS.md",
    "memory/MEMORY.md"
  ]
}
