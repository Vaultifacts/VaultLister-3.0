{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f*)",
      "Bash(git push * -f*)",
      "Bash(git push * --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase -i*)",
      "Bash(git checkout .*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git tag -d*)",
      "Bash(git add -A)",
      "Bash(git add .)",
      "Bash(curl * | bash)",
      "Bash(* --no-verify*)",
      "Bash(bun run db:drop*)",
      "Bash(bun run db:reset*)",
      "Bash(docker compose down -v*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(npm publish*)",
      "Bash(bun publish*)",
      "Bash(*HUSKY=0*)",
      "Bash(git config core.hookspath*)",
      "Bash(git config core.hooksPath*)",
      "Bash(git restore .*)",
      "Bash(git restore --staged .*)"
    ]
  },
  "hooks": {},
  "memory": [
    "memory/STATUS.md",
    "memory/MEMORY.md"
  ]
}
