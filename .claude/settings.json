{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push * --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase -i*)",
      "Bash(git checkout .*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git tag -d*)",
      "Bash(git add -A)",
      "Bash(git add .)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(* --no-verify*)",
      "Bash(bun run db:drop*)",
      "Bash(bun run db:reset*)",
      "Bash(docker compose down -v*)",
      "Bash(rm -rf src/*)",
      "Bash(rm -rf e2e/*)",
      "Bash(rm -rf .github/*)",
      "Bash(npm publish*)",
      "Bash(bun publish*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-bash.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-files.sh \"$CLAUDE_TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-commit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-init.sh stop"
          }
        ]
      }
    ]
  },
  "statusLine": ".claude/statusline.sh",
  "memory": [
    "memory/STATUS.md",
    "memory/MEMORY.md"
  ]
}
