#!/usr/bin/env sh

echo "Running pre-commit checks..."

# === .env Protection ===
# Blocks .env and .env.local/.env.production/etc. but allows .env.example
if git diff --cached --name-only | grep -qE '^\.(env|env\.(local|production|development|test|staging))$'; then
    echo "ERROR: Attempting to commit .env file!"
    echo "The .env file should never be committed."
    exit 1
fi

# Helper: get staged source files (excludes tests, e2e, assets, app.js)
staged_src_files() {
    git diff --cached --name-only --diff-filter=ACM | grep -v "app\.js" | grep -vE "\.(css|html|md|svg)$" | grep -vE "\.(test|spec)\.(js|ts)$" | grep -v "e2e/" | grep -v "node_modules" | grep -v "src/tests/"
}

# Helper: get all staged JS files
staged_js_files() {
    git diff --cached --name-only --diff-filter=ACM | grep "\.js$" | grep -v "node_modules"
}

# Helper: get staged test files
staged_test_files() {
    git diff --cached --name-only --diff-filter=ACM | grep -E "\.(test|spec)\.js$"
}

# Check for console.log statements (warn only)
echo "Checking for debug statements..."
CONSOLE_LOGS=""
for f in $(git diff --cached --name-only --diff-filter=ACM 2>/dev/null); do
    [ -f "$f" ] && grep -ql "console.log" "$f" 2>/dev/null && echo "$f" | grep -qv "test" && echo "$f" | grep -qv "scripts" && CONSOLE_LOGS="$CONSOLE_LOGS $f" || true
done
if [ -n "$CONSOLE_LOGS" ]; then
    echo "Warning: Found console.log statements. Consider removing before production."
fi

# Check for hardcoded secrets (skip test files — they legitimately reference tokens)
echo "Checking for potential secrets..."
SECRET_FOUND=""
for f in $(staged_src_files 2>/dev/null); do
    [ -f "$f" ] || continue
    MATCH=$(grep -IE "(password|secret|api_key|apikey|token)\s*[:=]\s*['\"][^'\"]{8,}" "$f" 2>/dev/null | grep -vE "_(at|by|id|type|count|name|status|expires|created|updated)\b" | grep -v "test" | grep -v "example" | grep -v "demo" | grep -v "process.env" | grep -v "data-" | grep -v "placeholder" | grep -v "aria-" || true)
    if [ -n "$MATCH" ]; then
        echo "$f: $MATCH"
        SECRET_FOUND="1"
    fi
done
if [ -n "$SECRET_FOUND" ]; then
    echo "Error: Potential hardcoded secrets detected!"
    exit 1
fi

# For app.js specifically, check only new/changed lines in the diff
if git diff --cached --name-only --diff-filter=ACM | grep -q "app\.js"; then
    APPJS_SECRETS=$(git diff --cached -- src/frontend/app.js | grep "^+" | grep -v "^+++" | grep -IE "(password|secret|api_key|apikey)\s*[:=]\s*['\"][^'\"]{8,}" | grep -vE "_(at|by|id|type|count|name|status|expires|created|updated)\b" | grep -vi "test\|example\|process\.env\|getItem\|setItem\|removeItem\|localStorage\|sessionStorage" || true)
    if [ -n "$APPJS_SECRETS" ]; then
        echo "Error: Potential hardcoded secrets detected in app.js diff:"
        echo "$APPJS_SECRETS"
        exit 1
    fi
fi

# Prevent committing temp/debug files
echo "Checking for temp files..."
TEMP_FILES=$(git diff --cached --name-only | grep -iE "(temp_.*\.json|notion_tmp\.json|tempnotion)" || true)
if [ -n "$TEMP_FILES" ]; then
    echo "Error: Attempting to commit temporary files:"
    echo "$TEMP_FILES"
    echo "These files should be in .gitignore."
    exit 1
fi

# Check for .only in test files (prevents broken CI)
# Note: .skip() is allowed — it's used for conditional test skipping
echo "Checking for .only in tests..."
ONLY_FOUND=""
for f in $(staged_test_files 2>/dev/null); do
    [ -f "$f" ] || continue
    MATCH=$(grep -InE "\.only\s*\(" "$f" 2>/dev/null || true)
    if [ -n "$MATCH" ]; then
        echo "$f:$MATCH"
        ONLY_FOUND="1"
    fi
done
if [ -n "$ONLY_FOUND" ]; then
    echo "Error: Found .only in test files — this would skip other tests in CI"
    exit 1
fi

# Check for debugger statements
echo "Checking for debugger statements..."
DEBUGGER=""
for f in $(staged_js_files 2>/dev/null); do
    [ -f "$f" ] || continue
    MATCH=$(grep -In "^\s*debugger" "$f" 2>/dev/null || true)
    if [ -n "$MATCH" ]; then
        echo "$f:$MATCH"
        DEBUGGER="1"
    fi
done
if [ -n "$DEBUGGER" ]; then
    echo "Error: Found debugger statements (above)"
    exit 1
fi

# Check for large files (>5MB)
# Uses for loop over git output directly — avoids mktemp and pipe-to-while deadlocks on Windows Git Bash
echo "Checking for large files..."
LARGE_FILES=""
for f in $(git diff --cached --name-only --diff-filter=ACM 2>/dev/null); do
    if [ -f "$f" ]; then
        size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo 0)
        if [ "$size" -gt 5242880 ]; then
            LARGE_FILES="$LARGE_FILES\n  $f ($((size/1048576))MB)"
        fi
    fi
done
if [ -n "$LARGE_FILES" ]; then
    echo "Error: Files over 5MB detected:"
    printf "%b\n" "$LARGE_FILES"
    exit 1
fi

# Syntax validation skipped — node --check hangs on ESM files, and Bun validates at runtime.
# If you need syntax checking, use: bun build --no-bundle --outdir /dev/null <file>

# === Auth Infrastructure Integrity Check ===
# Reads from the staged index (git show :file) to check what will actually be committed,
# not the working-tree version which may differ.
if git diff --cached --name-only | grep -q "^src/frontend/app.js$"; then
    echo "Checking auth infrastructure integrity in app.js..."
    if ! git show :src/frontend/app.js | grep -v '^\s*//' | grep -q 'token: this.state.token'; then
        echo ""
        echo "ERROR: store.persist() no longer saves the auth token!"
        echo "This breaks Remember Me. The line 'token: this.state.token' must exist in persist()."
        exit 1
    fi
    if ! git show :src/frontend/app.js | grep -v '^\s*//' | grep -q 'refreshToken: this.state.refreshToken'; then
        echo ""
        echo "ERROR: store.persist() no longer saves the refresh token!"
        echo "This breaks Remember Me. The line 'refreshToken: this.state.refreshToken' must exist in persist()."
        exit 1
    fi
fi

# === CSP Integrity Check ===
# Reads from the staged index (git show :file) to check what will actually be committed,
# not the working-tree version which may differ.
if git diff --cached --name-only | grep -q "^src/backend/middleware/securityHeaders.js$"; then
    echo "Checking CSP integrity in securityHeaders.js..."
    if ! git show :src/backend/middleware/securityHeaders.js | grep -v '^\s*//' | grep -q "'unsafe-inline'"; then
        echo ""
        echo "ERROR: CSP script-src missing 'unsafe-inline'!"
        echo "The SPA architecture requires unsafe-inline. Do not remove it."
        exit 1
    fi
fi

# === Critical File Test Gate ===
CRITICAL_FILES="src/frontend/app.js src/backend/middleware/securityHeaders.js"
CRITICAL_CHANGED=""
for cfile in $CRITICAL_FILES; do
    if git diff --cached --name-only | grep -q "^${cfile}$"; then
        CRITICAL_CHANGED="$CRITICAL_CHANGED $cfile"
    fi
done

if [ -n "$CRITICAL_CHANGED" ]; then
    # Skip test gate if changes are only comments or whitespace
    CODE_CHANGES=0
    for cfile in $CRITICAL_CHANGED; do
        REAL_DIFF=$(git diff --cached "$cfile" | grep "^[+-]" | grep -v "^[+-][+-][+-]" | grep -v "^[+-]\s*//" | grep -v "^[+-]\s*$" | grep -v "^[+-]\s*\*" | head -1 || true)
        if [ -n "$REAL_DIFF" ]; then
            CODE_CHANGES=1
            break
        fi
    done

    if [ "$CODE_CHANGES" -eq 0 ]; then
        echo "Critical files modified (comments/whitespace only) — skipping test gate."
    else
        echo ""
        echo "Critical files modified:$CRITICAL_CHANGED"
        echo "Running auth and security tests..."

        PORT="${PORT:-3000}"
        # Skip test gate on Windows (bun test hangs in Git Bash due to process handling)
        if [ "$(uname -o 2>/dev/null)" = "Msys" ] || [ -n "$MSYSTEM" ]; then
            echo "Windows detected — running tests via PowerShell..."
            if command -v powershell >/dev/null 2>&1; then
                powershell -NoProfile -ExecutionPolicy Bypass -Command "bun test src/tests/auth.test.js src/tests/security.test.js" || {
                    echo "ERROR: Auth/security tests FAILED on Windows! Commit blocked."
                    exit 1
                }
                echo "Auth/security tests passed (Windows/PowerShell)."
            else
                echo "WARNING: PowerShell not found — test gate skipped."
                echo "REMINDER: Run manually: bun test src/tests/auth.test.js src/tests/security.test.js"
            fi
        elif curl -s "http://localhost:${PORT}/api/health" > /dev/null 2>&1; then
            DISABLE_CSRF=true DISABLE_RATE_LIMIT=true bun test src/tests/auth.test.js src/tests/security.test.js 2>&1 || {
                echo ""
                echo "ERROR: Auth/security tests FAILED after modifying critical files!"
                echo "Commit blocked. Fix the failing tests or revert the changes."
                exit 1
            }
            echo "Auth/security tests passed."
        else
            echo ""
            echo "ERROR: Server not running on port ${PORT}. Cannot run tests against critical file changes."
            echo "Start the server with 'bun run dev:bg' before committing changes to:$CRITICAL_CHANGED"
            exit 1
        fi
    fi
fi

# === Core-bundle sync check ===
# core-bundle.js is built from the 12 component source files (utils.js, store.js,
# router.js, etc.) via build-dev-bundle.js. src/frontend/app.js is a legacy
# monolithic file NOT included in the core-bundle build — changes to app.js alone
# do not require a core-bundle rebuild.
# Rule: if any component source file is staged without core-bundle, require rebuild.
#       If only app.js changes, no rebuild required.
COMPONENT_STAGED=$(git diff --cached --name-only | grep -E "^src/frontend/(core|ui|pages/pages-core|handlers/handlers-core|init)\.js$" || true)
BUNDLE_STAGED=$(git diff --cached --name-only | grep "^src/frontend/core-bundle\.js$" || true)
if [ -n "$COMPONENT_STAGED" ] && [ -z "$BUNDLE_STAGED" ]; then
    echo "ERROR: Component source file(s) staged but core-bundle.js is NOT. Run: bun scripts/build-dev-bundle.js"
    echo "  Changed: $COMPONENT_STAGED"
    exit 1
fi
if [ -z "$COMPONENT_STAGED" ] && [ -n "$BUNDLE_STAGED" ]; then
    # Check if any component source has unstaged changes (forgot to git add)
    COMP_DIRTY=$(git diff --name-only -- src/frontend/core/utils.js src/frontend/core/store.js src/frontend/core/router.js src/frontend/init.js 2>/dev/null || true)
    if [ -n "$COMP_DIRTY" ]; then
        echo "ERROR: core-bundle.js is staged but component source files have unstaged changes. Stage them too."
        exit 1
    fi
    # Bundle changed due to handler/page files only, or version hash bump. Fine.
fi

# === Migration registration check ===
# Excludes migrations/pg/ — those are auto-discovered by scanning the directory
NEW_MIGRATIONS=$(git diff --cached --name-only --diff-filter=A | grep "^src/backend/db/migrations/.*\.sql$" | grep -v "^src/backend/db/migrations/pg/" || true)
DB_JS_STAGED=$(git diff --cached --name-only | grep "^src/backend/db/database\.js$" || true)
if [ -n "$NEW_MIGRATIONS" ] && [ -z "$DB_JS_STAGED" ]; then
    echo "ERROR: New migration file(s) staged but database.js is NOT staged."
    echo "  New migrations must be registered in the migrationFiles array."
    exit 1
fi

# === Bare JSON.parse check in route files ===
echo "Checking for new bare JSON.parse in routes..."
ROUTE_DIFFS=$(git diff --cached -- src/backend/routes/*.js | grep "^+" | grep -v "^+++" | grep "JSON\.parse(" | grep -v "safeJsonParse" || true)
if [ -n "$ROUTE_DIFFS" ]; then
    echo "WARNING: New bare JSON.parse() found in staged route files. Use safeJsonParse() instead:"
    echo "$ROUTE_DIFFS" | head -5
fi

# === SW cache version check ===
STATIC_CHANGED=$(git diff --cached --name-only | grep -E "^public/.*\.(js|css|html)$" | grep -v "sw\.js" || true)
SW_STAGED=$(git diff --cached --name-only | grep "^public/sw\.js$" || true)
if [ -n "$STATIC_CHANGED" ] && [ -z "$SW_STAGED" ]; then
    echo "WARNING: Static assets changed but sw.js not staged. Consider bumping CACHE_VERSION."
fi

# === Consistency Manifest Check ===
# Counts key infrastructure items and warns when they diverge from the manifest.
# This is a WARNING (not blocking) — update the manifest after intentional changes.
MANIFEST=".claude/consistency-manifest.json"
if [ -f "$MANIFEST" ] && command -v grep >/dev/null 2>&1; then
    echo "Checking consistency manifest..."

    MANIFEST_DENY=$(grep '"deny_patterns"' "$MANIFEST" | grep -o '[0-9]*' | head -1)
    # validate_bash_patterns and protected_files use "global" sentinel in manifest —
    # maintained globally (~/.claude/), no project-level count. Empty result → if [ -n ] guard skips. Intentional.
    MANIFEST_BASH=$(grep '"validate_bash_patterns"' "$MANIFEST" | grep -o '[0-9]*' | head -1)
    MANIFEST_FILES=$(grep '"protected_files"' "$MANIFEST" | grep -o '[0-9]*' | head -1)
    MANIFEST_AGENTS=$(grep '"agent_files"' "$MANIFEST" | grep -o '[0-9]*' | head -1)
    MANIFEST_MEMORY=$(grep '"memory_rules"' "$MANIFEST" | grep -o '[0-9]*' | head -1)

    ACTUAL_DENY=$(grep -c '"Bash(' .claude/settings.json 2>/dev/null || echo 0)
    ACTUAL_BASH=$(grep -c '^  "' .claude/hooks/validate-bash.sh 2>/dev/null || echo 0)
    ACTUAL_FILES=$(grep -c '^  "' .claude/hooks/protect-files.sh 2>/dev/null || echo 0)

    ACTUAL_AGENTS=0
    for f in .claude/agents/*.md; do
        [ -f "$f" ] && ACTUAL_AGENTS=$((ACTUAL_AGENTS + 1))
    done

    # Derive Claude Code project key dynamically from git root — portable across machines
    _GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
    if [ -n "$_GIT_ROOT" ]; then
        # Handle both Windows-style (C:/path) and Unix-style (/c/path) from git rev-parse
        if echo "$_GIT_ROOT" | grep -qE '^[A-Za-z]:/'; then
            _DRIVE=$(echo "$_GIT_ROOT" | sed 's|^\([A-Za-z]\):/.*|\1|' | tr '[:lower:]' '[:upper:]')
            _REST=$(echo "$_GIT_ROOT" | sed 's|^[A-Za-z]:/||' | tr '/' '-')
        else
            _DRIVE=$(echo "$_GIT_ROOT" | sed 's|^/\([a-zA-Z]\)/.*|\1|' | tr '[:lower:]' '[:upper:]')
            _REST=$(echo "$_GIT_ROOT" | sed 's|^/[a-zA-Z]/||' | tr '/' '-')
        fi
        MEMORY_DIR="$HOME/.claude/projects/${_DRIVE}--${_REST}/memory"
    else
        MEMORY_DIR="$HOME/.claude/projects/C--Users-Matt1-OneDrive-Desktop-vaultlister-3/memory"
    fi
    ACTUAL_MEMORY=0
    if [ -d "$MEMORY_DIR" ]; then
        for f in "$MEMORY_DIR"/*.md; do
            fname=$(basename "$f")
            [ "$fname" = "MEMORY.md" ] && continue
            [ -f "$f" ] && ACTUAL_MEMORY=$((ACTUAL_MEMORY + 1))
        done
    fi

    MANIFEST_MISMATCH=""
    if [ -n "$MANIFEST_DENY" ] && [ "$ACTUAL_DENY" != "$MANIFEST_DENY" ]; then
        MANIFEST_MISMATCH="${MANIFEST_MISMATCH}\n  deny_patterns:           manifest=$MANIFEST_DENY  actual=$ACTUAL_DENY  (.claude/settings.json)"
    fi
    if [ -n "$MANIFEST_BASH" ] && [ "$ACTUAL_BASH" != "$MANIFEST_BASH" ]; then
        MANIFEST_MISMATCH="${MANIFEST_MISMATCH}\n  validate_bash_patterns:  manifest=$MANIFEST_BASH  actual=$ACTUAL_BASH  (.claude/hooks/validate-bash.sh)"
    fi
    if [ -n "$MANIFEST_FILES" ] && [ "$ACTUAL_FILES" != "$MANIFEST_FILES" ]; then
        MANIFEST_MISMATCH="${MANIFEST_MISMATCH}\n  protected_files:         manifest=$MANIFEST_FILES  actual=$ACTUAL_FILES  (.claude/hooks/protect-files.sh)"
    fi
    if [ -n "$MANIFEST_AGENTS" ] && [ "$ACTUAL_AGENTS" != "$MANIFEST_AGENTS" ]; then
        MANIFEST_MISMATCH="${MANIFEST_MISMATCH}\n  agent_files:             manifest=$MANIFEST_AGENTS  actual=$ACTUAL_AGENTS  (.claude/agents/)"
    fi
    if [ -n "$MANIFEST_MEMORY" ] && [ "$ACTUAL_MEMORY" != "$MANIFEST_MEMORY" ]; then
        MANIFEST_MISMATCH="${MANIFEST_MISMATCH}\n  memory_rules:            manifest=$MANIFEST_MEMORY  actual=$ACTUAL_MEMORY  (memory/ excluding MEMORY.md)"
    fi

    if [ -n "$MANIFEST_MISMATCH" ]; then
        echo ""
        echo "WARNING: Consistency manifest mismatch detected!"
        printf "%b\n" "$MANIFEST_MISMATCH"
        echo ""
        echo "  Action required:"
        echo "  1. Update .claude/consistency-manifest.json with the new counts"
        echo "  2. Update the Notion Rules Architecture page to reflect the changes"
        echo "  3. Run: bash scripts/reconcile-notion.sh"
        echo ""
        echo "  (This is a warning, not a blocker. Commit proceeds — but update the manifest.)"
        echo ""
    else
        echo "Consistency manifest: OK"
    fi
fi

echo "Pre-commit checks passed!"
