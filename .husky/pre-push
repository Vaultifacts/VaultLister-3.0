#!/usr/bin/env sh

echo "Running pre-push checks..."

# Syntax check on critical files — reads from HEAD to check committed version
echo "Validating JavaScript syntax..."
_TMPFILE=$(mktemp /tmp/vl3-syntax-check-XXXXXX.js)
# app.js was archived to app-legacy.bak — check core-bundle.js instead
if git show HEAD:src/frontend/core-bundle.js > "$_TMPFILE" 2>/dev/null; then
    node --check "$_TMPFILE" || {
        rm -f "$_TMPFILE"
        echo "Syntax error in core-bundle.js (HEAD)! Push aborted."
        exit 1
    }
fi
rm -f "$_TMPFILE"
node --check src/backend/server.js || {
    echo "Syntax error in server.js! Push aborted."
    exit 1
}

# Verify auth infrastructure integrity — reads from HEAD (core-bundle.js is source of truth now)
echo "Checking auth infrastructure..."
if ! git show HEAD:src/frontend/core-bundle.js | grep -v '^\s*//' | grep -q 'token: this.state.token'; then
    echo "ERROR: store.persist() does not persist tokens! Push aborted."
    echo "The Remember Me feature requires token persistence in store.persist()."
    exit 1
fi
if ! git show HEAD:src/frontend/core-bundle.js | grep -v '^\s*//' | grep -q 'refreshToken: this.state.refreshToken'; then
    echo "ERROR: store.persist() does not persist refresh tokens! Push aborted."
    exit 1
fi

# Verify CSP integrity — reads from HEAD
echo "Checking CSP configuration..."
if ! git show HEAD:src/backend/middleware/securityHeaders.js | grep -v '^\s*//' | grep -q "'unsafe-inline'"; then
    echo "ERROR: CSP missing unsafe-inline! Push aborted."
    echo "The SPA requires unsafe-inline in script-src for compatibility."
    exit 1
fi

# Run unit tests — name-based regression detection (Q22)
# Compares failing test names against KNOWN_FAIL entries in .test-baseline.
# Any failure whose name is NOT in the list is a regression and blocks the push.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
BASELINE_FILE="${REPO_ROOT}/.test-baseline"
if [ -f "$BASELINE_FILE" ]; then
    KNOWN_FAILURES=$(grep -v '^\s*#' "$BASELINE_FILE" | sed -n 's/.*KNOWN_FAILURES=\([0-9]*\).*/\1/p' | head -1)
    KNOWN_FAIL_NAMES=$(grep -v '^\s*#' "$BASELINE_FILE" | grep '^KNOWN_FAIL: ' | sed 's/^KNOWN_FAIL: //' 2>/dev/null || true)
else
    KNOWN_FAILURES=0
    KNOWN_FAIL_NAMES=""
fi
# Validate KNOWN_FAILURES is numeric
case "$KNOWN_FAILURES" in
    ''|*[!0-9]*) KNOWN_FAILURES=0 ;;
esac

# Guard: if baseline is missing or empty, skip name-based regression check to prevent deadlock
if [ -z "$KNOWN_FAIL_NAMES" ] && [ "$KNOWN_FAILURES" -eq 0 ]; then
    echo "WARNING: .test-baseline missing or empty — skipping name-based regression check"
fi

# Validate .test-baseline format — catch entries missing the KNOWN_FAIL: prefix
if [ -f "$BASELINE_FILE" ]; then
    BAD_ENTRIES=$(grep -v '^\s*#' "$BASELINE_FILE" | grep -v '^\s*$' | grep -v '^KNOWN_FAIL' | grep -v '^#' | grep -v '^$' || true)
    if [ -n "$BAD_ENTRIES" ]; then
        echo "WARNING: .test-baseline has entries without KNOWN_FAIL: prefix:"
        echo "$BAD_ENTRIES" | head -5
        echo "  These entries will be IGNORED by the regression checker."
        echo "  Fix: prefix each with 'KNOWN_FAIL: '"
    fi
fi

echo "Running unit tests (named baseline: $(echo "$KNOWN_FAIL_NAMES" | grep -c . || echo 0) known failures)..."

# PostgreSQL check: unit tests require a running PostgreSQL (database.js now uses postgres.js).
# Skip unit test gate locally if DATABASE_URL is not set — CI always verifies with a real PG service.
_DB_URL=""
if [ -f .env ]; then
    _DB_URL=$(grep "^DATABASE_URL=" .env 2>/dev/null | cut -d'=' -f2 || true)
fi
_DB_URL="${DATABASE_URL:-$_DB_URL}"
if [ -z "$_DB_URL" ]; then
    echo "WARNING: DATABASE_URL not set — skipping unit tests locally (PostgreSQL required)."
    echo "  Unit tests will run in CI against a managed PostgreSQL service."
    echo "  To run locally: set DATABASE_URL in .env and start PostgreSQL (docker-compose up postgres)."
    _SKIP_UNIT_TESTS=1
else
    _SKIP_UNIT_TESTS=0
fi

PORT="${PORT:-3000}"
if [ "${_SKIP_UNIT_TESTS:-0}" -eq 1 ]; then
    echo "Unit test gate skipped (no DATABASE_URL)."
elif curl -s --ipv4 "http://localhost:${PORT}/api/health" > /dev/null 2>&1 || curl -s "http://127.0.0.1:${PORT}/api/health" > /dev/null 2>&1; then
    BUN_BIN=$(command -v bun 2>/dev/null || echo "/home/openclawuser/.bun/bin/bun")
    TEST_OUTPUT=$(DISABLE_CSRF=true DISABLE_RATE_LIMIT=true timeout 300 "$BUN_BIN" test src/tests/ 2>&1) || true

    # Guard: if test runner produced no output, it likely crashed or timed out immediately
    if [ -z "$TEST_OUTPUT" ]; then
        echo "WARNING: Test runner produced no output — skipping regression check"
        TEST_OUTPUT="0 fail"
    fi

    FAIL_COUNT=$(echo "$TEST_OUTPUT" | sed -n 's/^[[:space:]]*\([0-9]*\)[[:space:]]*fail.*/\1/p' | tail -1)
    FAIL_COUNT="${FAIL_COUNT:-0}"
    case "$FAIL_COUNT" in
        ''|*[!0-9]*) FAIL_COUNT=0 ;;
    esac
    echo "$TEST_OUTPUT" | tail -5

    # Name-based regression check: any failure NOT in the known list blocks the push
    # Strip trailing timing suffix (e.g. " [203.00ms]") before comparison so entries
    # in .test-baseline do not need timing values (which vary between runs).
    # Skip entirely when no known failures are defined (avoids deadlock on missing baseline).
    REGRESSIONS=""
    if [ -n "$KNOWN_FAIL_NAMES" ] || [ "$KNOWN_FAILURES" -gt 0 ]; then
        _FAIL_NAMES_TMP=$(echo "$TEST_OUTPUT" | grep '^(fail) ' | sed 's/^(fail) //')
        IFS_BAK="$IFS"
        IFS='
'
        for fail_name in $_FAIL_NAMES_TMP; do
            IFS="$IFS_BAK"
            [ -z "$fail_name" ] && continue
            # Remove optional trailing " [NNN.NNms]" suffix
            fail_name_stripped=$(printf '%s' "$fail_name" | sed 's/ \[[0-9][0-9.]*ms\]$//')
            if ! printf '%s\n' "$KNOWN_FAIL_NAMES" | grep -qxF "$fail_name_stripped"; then
                REGRESSIONS="${REGRESSIONS}  ${fail_name}
"
            fi
            IFS='
'
        done
        IFS="$IFS_BAK"
    fi

    if [ -n "$REGRESSIONS" ]; then
        echo ""
        echo "REGRESSION DETECTED — failures not in .test-baseline KNOWN_FAIL list:"
        echo "$REGRESSIONS"
        echo "Push aborted. Fix the regression or add to KNOWN_FAIL list in .test-baseline."
        exit 1
    fi
    echo "Test gate passed (${FAIL_COUNT} failures — all are known pre-existing)."
else
    echo "ERROR: Server not running on port ${PORT}. Cannot run tests."
    echo "Start the server with 'bun run dev:bg' then try the push again."
    exit 1
fi

echo "Pre-push checks passed!"
