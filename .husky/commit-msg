#!/usr/bin/env sh

COMMIT_MSG=$(head -1 "$1")

# Reject empty commit messages
if [ -z "$COMMIT_MSG" ] || echo "$COMMIT_MSG" | grep -qE "^[[:space:]]*$"; then
    echo "Error: Commit message cannot be empty."
    exit 1
fi

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
    exit 0
fi

PATTERN="^(\[AUTO\] )?(feat|fix|chore|docs|style|refactor|perf|test|ci|build|revert)(\(.+\))?: .{3,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "Error: Commit message must follow Conventional Commits format:"
    echo "  type: description"
    echo ""
    echo "  Types: feat, fix, chore, docs, style, refactor, perf, test, ci, build, revert"
    echo "  Examples:"
    echo "    feat: add dark mode toggle"
    echo "    fix: resolve login redirect loop"
    echo "    chore: update dependencies"
    echo ""
    echo "  Your message: $COMMIT_MSG"
    exit 1
fi

# Warn when fix:/feat: commits lack Notion-Done trailer
# These commits likely resolve Sprint Board items and should mark them Done.
FULL_MSG=$(cat "$1")
if echo "$COMMIT_MSG" | grep -qE "^(\[AUTO\] )?(fix|feat):"; then
    if ! echo "$FULL_MSG" | grep -qE "^Notion-Done:"; then
        echo ""
        echo "  WARNING: This fix/feat commit has no Notion-Done: trailer."
        echo "  If this resolves a Sprint Board item, add a trailer line:"
        echo "    Notion-Done: <page-id-from-notion>"
        echo "  (amend the commit to add it, or update Notion manually)"
        echo ""
    fi
fi

# Validate Notion-Done trailer IDs (warning only — does not block commit)
if echo "$FULL_MSG" | grep -qE "^Notion-Done:"; then
    BAD_IDS=""
    while IFS= read -r line; do
        case "$line" in
            Notion-Done:*)
                raw_id=$(echo "$line" | sed 's/^Notion-Done:[[:space:]]*//')
                # Accept 32 hex chars with or without standard UUID dashes
                if ! echo "$raw_id" | grep -qiE "^[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}$|^[0-9a-f]{32}$"; then
                    BAD_IDS="$BAD_IDS\n  '$raw_id'"
                fi
                ;;
        esac
    done <<EOF
$(echo "$FULL_MSG")
EOF
    if [ -n "$BAD_IDS" ]; then
        echo "Warning: Notion-Done trailer contains malformed ID(s):$BAD_IDS"
        echo "  Expected: 32 hex chars (with or without dashes), e.g. Notion-Done: abc123def456abc123def456abc123de"
        # Warning only — do not exit 1
    fi
fi
