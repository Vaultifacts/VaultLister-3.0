#!/usr/bin/env sh

COMMIT_MSG=$(head -1 "$1")

# Reject empty commit messages
if [ -z "$COMMIT_MSG" ] || echo "$COMMIT_MSG" | grep -qE "^[[:space:]]*$"; then
    echo "Error: Commit message cannot be empty."
    exit 1
fi

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
    exit 0
fi

PATTERN="^(\[AUTO\] )?(feat|fix|chore|docs|style|refactor|perf|test|ci|build|revert)(\(.+\))?: .{3,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "Error: Commit message must follow Conventional Commits format:"
    echo "  type: description"
    echo ""
    echo "  Types: feat, fix, chore, docs, style, refactor, perf, test, ci, build, revert"
    echo "  Examples:"
    echo "    feat: add dark mode toggle"
    echo "    fix: resolve login redirect loop"
    echo "    chore: update dependencies"
    echo ""
    echo "  Your message: $COMMIT_MSG"
    exit 1
fi

# BLOCK fix:/feat: commits that lack both Notion-Done: and Notion-Skip: trailers.
# Every fix/feat commit either resolves a Sprint Board item (Notion-Done: <id>)
# or explicitly declares it doesn't (Notion-Skip: <reason>). No third option.
FULL_MSG=$(cat "$1")
if echo "$COMMIT_MSG" | grep -qE "^(\[AUTO\] )?(fix|feat):"; then
    HAS_DONE=$(echo "$FULL_MSG" | grep -cE "^Notion-Done:" || true)
    HAS_SKIP=$(echo "$FULL_MSG" | grep -cE "^Notion-Skip:" || true)
    if [ "$HAS_DONE" -eq 0 ] && [ "$HAS_SKIP" -eq 0 ]; then
        echo ""
        # Auto-search Sprint Board for matching items
        LOOKUP_SCRIPT="scripts/notion-sprint-lookup.py"
        SUGGESTED_ID=""
        if command -v python >/dev/null 2>&1 && [ -f "$LOOKUP_SCRIPT" ]; then
            SUGGESTED_ID=$(PYTHONIOENCODING=utf-8 python "$LOOKUP_SCRIPT" auto "$COMMIT_MSG" 2>/dev/null || true)
        fi

        echo ""
        echo "  BLOCKED: fix/feat commits MUST include a Notion trailer."
        echo ""
        if [ -n "$SUGGESTED_ID" ]; then
            echo "  SUGGESTED match from Sprint Board:"
            echo "    Notion-Done: $SUGGESTED_ID"
            echo ""
            echo "  To use this, amend your commit message to include the line above."
            echo ""
        fi
        echo "  If this resolves a Sprint Board item:"
        echo "    Notion-Done: <page-id>"
        echo ""
        echo "  If this does NOT relate to any Sprint Board item:"
        echo "    Notion-Skip: <reason>"
        echo ""
        echo "  Find page IDs: python scripts/notion-sprint-lookup.py match \"your commit msg\""
        echo ""
        exit 1
    fi
fi

# Validate Notion-Done trailer IDs — BLOCK on malformed IDs
if echo "$FULL_MSG" | grep -qE "^Notion-Done:"; then
    BAD_IDS=""
    for raw_id in $(echo "$FULL_MSG" | grep "^Notion-Done:" | sed 's/^Notion-Done:[[:space:]]*//'); do
        if ! echo "$raw_id" | grep -qiE "^[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}$|^[0-9a-f]{32}$"; then
            BAD_IDS="$BAD_IDS  '$raw_id'\n"
        fi
    done
    if [ -n "$BAD_IDS" ]; then
        echo "BLOCKED: Notion-Done trailer contains malformed ID(s):"
        printf "$BAD_IDS"
        echo "  Expected: 32 hex chars (with or without dashes)"
        exit 1
    fi
fi

# Validate Notion-Skip has a reason (not empty)
if echo "$FULL_MSG" | grep -qE "^Notion-Skip:"; then
    SKIP_REASON=$(echo "$FULL_MSG" | grep "^Notion-Skip:" | sed 's/^Notion-Skip:[[:space:]]*//')
    if [ -z "$SKIP_REASON" ] || echo "$SKIP_REASON" | grep -qE "^[[:space:]]*$"; then
        echo "BLOCKED: Notion-Skip: requires a reason."
        echo "  Example: Notion-Skip: infra-only change, no Sprint Board item"
        exit 1
    fi
fi
