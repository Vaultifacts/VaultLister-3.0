#!/usr/bin/env sh

COMMIT_MSG=$(head -1 "$1")

# Reject empty commit messages
if [ -z "$COMMIT_MSG" ] || echo "$COMMIT_MSG" | grep -qE "^[[:space:]]*$"; then
    echo "Error: Commit message cannot be empty."
    exit 1
fi

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
    exit 0
fi

# All commit types that produce functional changes require trailers.
# docs/style/ci are exempt — maintenance and non-functional changes.
TRAILER_REQUIRED_TYPES="feat|fix|chore|refactor|perf|test|build|revert"
TRAILER_EXEMPT_TYPES="docs|style|ci"

PATTERN="^(\[AUTO\] )?(feat|fix|chore|docs|style|refactor|perf|test|ci|build|revert)(\(.+\))?: .{3,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "Error: Commit message must follow Conventional Commits format:"
    echo "  type: description"
    echo ""
    echo "  Types: feat, fix, chore, docs, style, refactor, perf, test, ci, build, revert"
    echo "  Examples:"
    echo "    feat: add dark mode toggle"
    echo "    fix: resolve login redirect loop"
    echo "    chore: update dependencies"
    echo ""
    echo "  Your message: $COMMIT_MSG"
    exit 1
fi

# Read full message for trailer checks
FULL_MSG=$(cat "$1")

# BLOCK fix:/feat: commits without Verified: trailer
# Forces explicit statement of what was tested — not just "built it"
if echo "$COMMIT_MSG" | grep -qE "^(\[AUTO\] )?($TRAILER_REQUIRED_TYPES):"; then
    HAS_VERIFIED=$(echo "$FULL_MSG" | grep -cE "^Verified:" || true)
    if [ "$HAS_VERIFIED" -eq 0 ]; then
        echo ""
        echo "  BLOCKED: fix/feat commits MUST include a Verified: trailer."
        echo ""
        echo "  State what you tested. Examples:"
        echo "    Verified: tests pass, failure case tested (commit without trailer blocked)"
        echo "    Verified: bun test auth+security pass, curl API returns 200"
        echo "    Verified: browser walkthrough — dashboard loads, zero console errors"
        echo ""
        echo "  This prevents declaring work done without actually verifying it."
        echo ""
        exit 1
    fi
    # Verify the Verified: trailer has actual content
    VERIFIED_CONTENT=$(echo "$FULL_MSG" | grep "^Verified:" | sed 's/^Verified:[[:space:]]*//')
    if [ -z "$VERIFIED_CONTENT" ] || echo "$VERIFIED_CONTENT" | grep -qE "^[[:space:]]*$"; then
        echo "BLOCKED: Verified: trailer cannot be empty."
        echo "  State specifically what you tested."
        exit 1
    fi
fi
