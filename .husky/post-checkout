#!/usr/bin/env sh
# Auto-install dependencies if package.json changed on branch switch
# Args: $1=prev_HEAD $2=new_HEAD $3=1 for branch checkout, 0 for file checkout
[ "$3" = "1" ] || exit 0

if ! git diff --name-only "$1" "$2" 2>/dev/null | grep -q "package.json"; then
    exit 0
fi

echo "[post-checkout] package.json differs -- running bun install..."
bun install
