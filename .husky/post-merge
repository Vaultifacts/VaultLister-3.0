#!/usr/bin/env sh
# Auto-install dependencies if package.json changed during git merge/pull

changed_files=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)
if echo "$changed_files" | grep -q "package.json"; then
    echo "[post-merge] package.json changed -- running bun install..."
    bun install
fi
